{
  "name": "nextjs-website-template",
  "version": "1.3.0",
  "private": false,
  "description": "A clean Next.js 16 + Tailwind v4 + MDX template for building personal/business websites. Real URLs for every page, content as MDX files, zero CMS to babysit.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
